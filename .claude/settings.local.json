{
  "permissions": {
    "allow": [
      "WebFetch(domain:copatim.com)",
      "PowerShell(node -v)",
      "PowerShell(npm -v)",
      "PowerShell(npx --yes create-next-app@latest --help 2>&1)",
      "PowerShell(npm install three @react-three/fiber @react-three/drei framer-motion lenis @studio-freight/react-lenis 2>&1)",
      "PowerShell(npm install three @react-three/fiber @react-three/drei framer-motion lenis 2>&1)",
      "PowerShell(npm install @types/three --save-dev 2>&1)",
      "PowerShell(npm run lint 2>&1)",
      "PowerShell(npm run build 2>&1)",
      "PowerShell(npm run dev 2>&1)",
      "PowerShell(Start-Sleep -Seconds 8; try { $r = Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing -TimeoutSec 25; \"STATUS: $\\($r.StatusCode\\) LEN: $\\($r.Content.Length\\)\" } catch { \"ERROR: $\\($_.Exception.Message\\)\" })",
      "Skill(run)",
      "Skill(run:*)",
      "PowerShell(Start-Sleep -Seconds 10; try { $r = Invoke-WebRequest -Uri \"http://127.0.0.1:3000\" -UseBasicParsing -TimeoutSec 25; \"STATUS: $\\($r.StatusCode\\) LEN: $\\($r.Content.Length\\)\" } catch { \"ERROR: $\\($_.Exception.Message\\)\" })",
      "PowerShell(Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue)",
      "WebFetch(domain:unsplash.com)",
      "PowerShell(Stop-Process -Id 41460 -Force -Confirm:$false -ErrorAction SilentlyContinue)",
      "PowerShell(Stop-Process -Id 35732 -Force -Confirm:$false -ErrorAction SilentlyContinue)",
      "PowerShell(Start-Sleep -Seconds 10; try { $r = Invoke-WebRequest -Uri \"http://127.0.0.1:3000\" -UseBasicParsing -TimeoutSec 25; \"STATUS: $\\($r.StatusCode\\)\" } catch { \"ERROR: $\\($_.Exception.Message\\)\" })",
      "PowerShell(Start-Sleep -Seconds 6; try { $r = Invoke-WebRequest -Uri \"http://127.0.0.1:3000\" -UseBasicParsing -TimeoutSec 20; \"STATUS: $\\($r.StatusCode\\)\" } catch { \"ERROR: $\\($_.Exception.Message\\)\" })"
    ]
  }
}
